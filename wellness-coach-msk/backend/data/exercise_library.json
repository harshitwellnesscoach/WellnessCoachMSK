      "type": "cv",
      "description": "Hip hinge from lying to lift the pelvis off the floor",
      "default_sets": 2,
      "default_reps": 10,
      "rest_seconds": 45,
      "cues": ["Drive through heels", "Squeeze glutes at top", "Lower slowly in 3 seconds"],
      "contraindications": []
    },
    {
      "id": "cat_cow",
      "name": "Cat-Cow",
