{
  "exercises": [
    {
      "id": "pelvic_tilt",
      "name": "Pelvic Tilt",
      "type": "cv",
      "description": "Gentle flattening of the lower back against the floor",
      "default_sets": 2,
      "default_reps": 10,
      "rest_seconds": 30,
      "cues": ["Breathe out as you flatten", "Keep shoulders relaxed", "Hold 2 seconds at top"],
      "contraindications": ["acute_disc_herniation"]
    },
    {
      "id": "glute_bridge",
